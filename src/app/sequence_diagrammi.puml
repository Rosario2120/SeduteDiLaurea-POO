' ============================================================

@startuml
title Sequence Diagram - Prenotazione Seduta di Laurea

actor Studente as S
boundary GUI_Seduta as GUI
control SedutaController as SC
entity SedutaPostgresDAO as DAO
database PostgreSQL as DB

S -> GUI : Seleziona seduta
GUI -> SC : prenotaSeduta(idStudente, idSeduta)
SC -> DAO : insertPrenotazione(idStudente, idSeduta)
DAO -> DB : INSERT INTO prenotazioni(idStudente, idSeduta)
DB --> DAO : OK
DAO --> SC : conferma
SC --> GUI : prenotazione completata
GUI --> S : Conferma prenotazione

@enduml